# ── Saarthi environment ───────────────────────────────────────────────
# Every integration is OPTIONAL. With none set, the app runs in DEMO_MODE
# with deterministic planning, browser voice fallback, and simulated actions.
# Add keys to make each layer fully live — no code changes required.

# Gemini (the brain) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Sarvam AI (voice ears + mouth) — https://dashboard.sarvam.ai
SARVAM_API_KEY=
SARVAM_TTS_MODEL=bulbul:v3
# Valid bulbul:v3 speakers: priya, neha, ritu, pooja, simran, kavya, ishita, shreya,
# aditya, rahul, rohan, amit, dev, varun, kabir, shubh, advait, anand (and more).
SARVAM_TTS_SPEAKER=priya
SARVAM_STT_MODEL=saaras:v3

# Google Calendar + Gmail (the hands) — OAuth2 client + a stored refresh token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_REFRESH_TOKEN=

# Force demo mode even if keys are present (useful for a guaranteed-stable demo link)
# DEMO_MODE=true
